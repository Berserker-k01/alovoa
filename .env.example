# EyaLove environment configuration
# Copy this file to ".env" and fill in the values, then run: docker compose up -d
# Never commit your real ".env" file.

# ---- Server ----
SERVER_PORT=8081
JAVA_OPTS=-Xmx512m -XX:+HeapDumpOnOutOfMemoryError

# ---- Database ----
DB_NAME=eyalove
DB_USER=eyalove
DB_PASSWORD=change_me_db_password
DB_ROOT_PASSWORD=change_me_root_password

# ---- Transparent database encryption (REQUIRED) ----
# APP_TEXT_KEY must be exactly 16, 24 or 32 characters long.
# APP_TEXT_SALT must be exactly 16 characters long.
APP_TEXT_KEY=0123456789abcdef0123456789abcdef
APP_TEXT_SALT=0123456789abcdef

# ---- Default admin account (created on first start) ----
APP_ADMIN_EMAIL=admin@eyalove.com
APP_ADMIN_KEY=change_me_admin_password

# ---- Security ----
# Long random string used to sign the remember-me cookie.
APP_LOGIN_REMEMBER_KEY=change_me_to_a_long_random_string

# ---- Public URLs ----
APP_DOMAIN=http://localhost:8081
APP_URL_FRONT_END=http://localhost:8081

# ---- OAuth2 (optional - leave blank to keep dummy values; the app still boots) ----
OAUTH_GOOGLE_CLIENT_ID=dummy
OAUTH_GOOGLE_CLIENT_SECRET=dummy
OAUTH_FACEBOOK_CLIENT_ID=dummy
OAUTH_FACEBOOK_CLIENT_SECRET=dummy

# ---- Mail (SMTP) ----
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=no-reply@eyalove.com
MAIL_PASSWORD=change_me_mail_password
# Set to true to verify the SMTP connection at startup.
MAIL_TEST_CONNECTION=false

# ---- Paid access (account activation fee) ----
# These are defaults seeded on first start; the admin can change them at runtime.
ACCESS_PAYMENT_ENABLED=false
ACCESS_PRICE=11000
ACCESS_CURRENCY=XOF

# ---- Tchin Mobile Money provider ----
TCHIN_BASE_URL=https://api.tchin.io
TCHIN_API_KEY=
TCHIN_SECRET=
TCHIN_WEBHOOK_SECRET=change_me_webhook_secret
TCHIN_RETURN_URL=http://localhost:8081/payment/return
TCHIN_CALLBACK_URL=http://localhost:8081/payment/webhook/tchin
